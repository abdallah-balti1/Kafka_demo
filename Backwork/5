// Import
import { getAllTeams, getTeams, getTeamsByIds, getInitiativeTeams } from './api';
import { TEAMS_INITIATIVE_FETCH_REQUEST } from './constants';

// Nouvelle saga
export function* fetchInitiativeTeamsSaga(): SagaType {
  try {
    const response: ResponseType = yield authenticatedCall(getInitiativeTeams);
    yield put(fetchTeamsSuccess(modelizeTeamsState(response.data)));
  } catch (error) {
    yield put(fetchTeamsError(error));
    yield call(handleAPIExceptions, error);
  }
}

// Dans teamsSagas()
