import React from "react";

const GlobalRatingCard = ({
  globalRating,
  categories = [],
  isLoading = false,
}) => {
  if (isLoading) {
    return <div>Loading...</div>;
  }

  return (
    <div className="global-rating-card">
      <div className="global-rating-card__header">
        <h2>Global rating</h2>
      </div>

      <div className="global-rating-card__summary">
        <div className="global-rating-card__score">{globalRating || "-"}</div>
      </div>

      <div className="global-rating-card__categories">
        {categories.map(category => (
          <div key={category.name} className="global-rating-card__category">
            <span>{category.name}</span>
            <span>{category.rating || "-"}</span>
          </div>
        ))}
      </div>
    </div>
  );
};

export default GlobalRatingCard;
