// @flow
import React from 'react';
import { FormattedMessage } from 'react-intl';
import Style from './GlobalRating.style';

type RatingLevel = 'VERY_LOW' | 'LOW' | 'MEDIUM' | 'HIGH' | 'VERY_HIGH' | null;

type AssessmentRating = {
  category: string,
  rating: RatingLevel,
  weight: number,
};

type OwnPropsType = {
  initiative: Object,
  assessments?: AssessmentRating[],
  globalRating?: RatingLevel,
};

type PropsType = OwnPropsType;

const RATING_CONFIG: { [RatingLevel]: { label: string, color: string, rank: number } } = {
  VERY_LOW:  { label: 'Very low',  color: '#4CAF50', rank: 1 },
  LOW:       { label: 'Low',       color: '#8BC34A', rank: 2 },
  MEDIUM:    { label: 'Medium',    color: '#FFC107', rank: 3 },
  HIGH:      { label: 'High',      color: '#FF9800', rank: 4 },
  VERY_HIGH: { label: 'Very high', color: '#F44336', rank: 5 },
};

const ALL_LEVELS: RatingLevel[] = ['VERY_LOW', 'LOW', 'MEDIUM', 'HIGH', 'VERY_HIGH'];

const RatingBadge = ({ rating }: { rating: RatingLevel }) => {
  if (!rating) return <Style.EmptyBadge>—</Style.EmptyBadge>;
  const config = RATING_CONFIG[rating];
  return (
    <Style.RatingBadge color={config.color}>
      {config.label}
    </Style.RatingBadge>
  );
};

const RatingScale = ({ rating }: { rating: RatingLevel }) => {
  const activeRank = rating ? RATING_CONFIG[rating].rank : 0;
  return (
    <Style.ScaleContainer>
      {ALL_LEVELS.map((level) => {
        const config = RATING_CONFIG[level];
        const isActive = config.rank <= activeRank;
        return (
          <Style.ScaleDot
            key={level}
            color={config.color}
            isActive={isActive}
            title={config.label}
          />
        );
      })}
    </Style.ScaleContainer>
  );
};

const GlobalRating = ({ initiative, assessments = [], globalRating }: PropsType) => {
  return (
    <Style.Container>
      {/* Header */}
      <Style.HeaderContainer>
        <Style.Title>
          <FormattedMessage id="INITIATIVE_CARD.GLOBAL_RATING.TITLE" defaultMessage="Global Rating" />
        </Style.Title>
      </Style.HeaderContainer>

      {/* Global Rating Summary */}
      <Style.GlobalRatingContainer>
        <Style.GlobalRatingLabel>
          <FormattedMessage id="INITIATIVE_CARD.GLOBAL_RATING.OVERALL" defaultMessage="Overall Risk Rating" />
        </Style.GlobalRatingLabel>
        <Style.GlobalRatingValue>
          <RatingBadge rating={globalRating} />
          <RatingScale rating={globalRating} />
        </Style.GlobalRatingValue>
      </Style.GlobalRatingContainer>

      {/* Assessments breakdown */}
      {assessments.length > 0 && (
        <Style.AssessmentsContainer>
          <Style.AssessmentsHeader>
            <Style.ColumnLabel>
              <FormattedMessage id="INITIATIVE_CARD.GLOBAL_RATING.CATEGORY" defaultMessage="Category" />
            </Style.ColumnLabel>
            <Style.ColumnLabel>
              <FormattedMessage id="INITIATIVE_CARD.GLOBAL_RATING.RATING" defaultMessage="Rating" />
            </Style.ColumnLabel>
          </Style.AssessmentsHeader>

          {assessments.map((assessment, index) => (
            <Style.AssessmentRow key={index}>
              <Style.CategoryName>{assessment.category}</Style.CategoryName>
              <Style.RatingCell>
                <RatingBadge rating={assessment.rating} />
              </Style.RatingCell>
            </Style.AssessmentRow>
          ))}
        </Style.AssessmentsContainer>
      )}

      {assessments.length === 0 && (
        <Style.EmptyState>
          <FormattedMessage
            id="INITIATIVE_CARD.GLOBAL_RATING.NO_ASSESSMENTS"
            defaultMessage="No assessments available yet."
          />
        </Style.EmptyState>
      )}
    </Style.Container>
  );
};

export default GlobalRating;
