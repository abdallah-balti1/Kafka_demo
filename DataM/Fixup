def get_mu_version(wb: Workbook):
    """Return MU version based on workbook structure and headers."""

    required_worksheets_mu_2 = {
        WS_DATA_NAME,
        WS_INITIAL_DATA_NAME,
        WS_LOOKUP_DATA_NAME,
    }

    adl_columns_v3 = {
        "Max ADL in",
        "Max ADL out",
        "ADL in",
        "ADL out",
        "New ADL in",
        "New ADL out",
        "Effective NAV date",
    }

    # 1) Detect V3 by scanning all worksheets
    for ws in wb.worksheets:
        headers = {cell.value for cell in ws[1] if cell.value}
        if adl_columns_v3 & headers:
            return MASS_UPDATE_VERSION_3

    # 2) Detect V2 with old worksheet names
    available_worksheets = set(wb.sheetnames)
    if required_worksheets_mu_2 <= available_worksheets:
        return MASS_UPDATE_VERSION_2

    # 3) Otherwise V1
    return MASS_UPDATE_VERSION_1
