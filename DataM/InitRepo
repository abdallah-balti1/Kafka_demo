"""Defines the Initiative repository"""

from datetime import date, datetime

import uuid
from errors import EntityNotFound
from sqlalchemy import Sequence, select, text
from sqlalchemy.orm import joinedload

from db import db
from models import Initiative
from util.business_rule_assessment import resolve_assessement_team
from util.manager_team_assessment import get_project_owner_by_assessment_team


class InitiativeRepository:
    """The repository for the initiative"""

    @staticmethod
    def get(initiative_id):
        """Get the initiative linked with the initiative id"""
        initiative = db.session.scalars(
            select(Initiative).where(Initiative.id == initiative_id, Initiative.is_active.is_(True))
        ).first()
        if initiative is None:
            raise EntityNotFound("initiative", initiative_id)
        return initiative

    @staticmethod
    def get_by_initiative_id(initiative_id: str) -> Initiative:
        """Get the initiative linked with the initiative id"""
        obj = db.session.scalars(
            select(Initiative).where(Initiative.id == initiative_id)
        ).first()
        if obj is None:
            raise EntityNotFound("initiative", initiative_id)
        return obj

    @staticmethod
    def get_all():
        """Get all active initiatives"""
        initiatives = db.session.scalars(
            select(Initiative).where(Initiative.is_active.is_(True))
        )
        return [initiative for initiative in initiatives]

    @staticmethod
    def delete(initiative_id):
        """Soft delete the initiative by setting is_active to False"""
        initiative = db.session.get(Initiative, initiative_id)
        if initiative is None:
            raise EntityNotFound("initiative", initiative_id)
        initiative.is_active = False
        db.session.flush()
        return initiative

    @staticmethod
    def _empty_to_none(value):
        if value is None:
            return None
        if isinstance(value, str):
            v = value.strip()
            if v == "" or v.lower() in {"none", "null", "undefined"}:
                return None
        return value

    @staticmethod
    def _date_or_none(value):
        value = InitiativeRepository._empty_to_none(value)
        if value is None:
            return None
        if isinstance(value, datetime):
            return value.date()
        if isinstance(value, date):
            return value
        if isinstance(value, str):
            v = value.strip()
            try:
                return datetime.fromisoformat(v.replace("Z", "+00:00")).date()
            except Exception:
                raise ValueError(f"Invalid date format: {value}")
        return value

