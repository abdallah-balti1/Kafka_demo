    @staticmethod
    def modify(initiative_id, **kwargs):
        initiative = db.session.scalars(
            select(Initiative).where(Initiative.id == initiative_id, Initiative.is_active.is_(True))
        ).first()
        if initiative is None:
            raise EntityNotFound("initiative", initiative_id)

        not_allowed = {"id"}

        # Normalize all incoming string values
        for k in list(kwargs.keys()):
            kwargs[k] = InitiativeRepository._empty_to_none(kwargs[k])

        # Normalize implementation_date if provided
        if "implementation_date" in kwargs:
            kwargs["implementation_date"] = InitiativeRepository._date_or_none(kwargs["implementation_date"])

        # Re-evaluate assessment and manager team if any rule field changed
        rule_fields = {
            "name", "summary", "product_type", "initiative_type", "sponsor",
            "sponsor_country", "asset_class", "management_company", "committee_date",
            "distribution_channel", "governance_required", "legal_form",
            "initiative_owner", "cosmos_id",
        }

        if any(field in kwargs for field in rule_fields):
            initiative_data_for_rules = {
                "name": kwargs.get("name", initiative.name),
                "summary": kwargs.get("summary", initiative.summary),
                "product_type": kwargs.get("product_type", initiative.product_type),
                "initiative_type": kwargs.get("initiative_type", initiative.initiative_type),
                "sponsor": kwargs.get("sponsor", initiative.sponsor),
                "sponsor_country": kwargs.get("sponsor_country", initiative.sponsor_country),
                "asset_class": kwargs.get("asset_class", initiative.asset_class),
                "management_company": kwargs.get("management_company", initiative.management_company),
                "committee_date": kwargs.get("committee_date", initiative.committee_date),
                "distribution_channel": kwargs.get("distribution_channel", initiative.distribution_channel),
                "governance_required": kwargs.get("governance_required", initiative.governance_required),
                "legal_form": kwargs.get("legal_form", initiative.legal_form),
                "initiative_owner": kwargs.get("initiative_owner", initiative.initiative_owner),
                "cosmos_id": kwargs.get("cosmos_id", initiative.cosmos_id),
            }
            initiative.assessment_team = resolve_assessement_team(initiative_data_for_rules)
            initiative.manager_team = get_project_owner_by_assessment_team(initiative.assessment_team)

        # Apply updates
        for field, value in kwargs.items():
            if field in not_allowed:
                continue
            if not hasattr(initiative, field):
                continue
            setattr(initiative, field, value)

        db.session.flush()
        return initiative
