from flask import Blueprint
from flask_restful import Api

from resources.template_config import TemplateConfigsResource

TEMPLATE_CONFIGS_BLUEPRINT = Blueprint("template_configs", __name__)
Api(TEMPLATE_CONFIGS_BLUEPRINT).add_resource(
    TemplateConfigsResource, "/template-configs", endpoint="template_configs"
)
