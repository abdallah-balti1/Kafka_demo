from flask_restful import Resource
from util.required_plm_authentication import authorized_plm_roles
from db import db
from models.template_config import TemplateConfig
from models.template import Template


class TemplateConfigsResource(Resource):
    """Get all template configs with their template name"""

    @staticmethod
    @authorized_plm_roles(
        [
            "INITIATIVE_OWNER",
            "INITIATIVE_COORDINATOR",
            "ADMIN",
            "INITIATIVE_ASSESSOR",
            "INITIATIVE_OVERSIGHT",
            "INITIATIVE_OBSERVER",
        ]
    )
    def get(user):
        results = (
            db.session.query(TemplateConfig.id, Template.name)
            .join(Template, TemplateConfig.template_id == Template.id)
            .all()
        )
        return [{"id": row.id, "name": row.name} for row in results]
