2. src/redux/entities/initiativesPipeline/hooks.js — Ajouter le hook
En suivant le même pattern que useFetchInitiativeOwners :
export const useFetchTemplateConfigs = (token, fetch, defaultValue) => {
  const [state, setState] = useState(defaultValue);

  useEffect(() => {
    if (fetch && token) {
      getTemplateConfigsData(token).then((response) => {
        setState(response);
      });
    }
  }, [token, fetch]);

  return { value: state };
};
