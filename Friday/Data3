export const useFetchTemplateConfigs = (
  token: ?string,
  shouldFetch: ?boolean,
  initialValue: ?any,
) =>
  useAsync<any>(
    async () => {
      if (shouldFetch) {
        const { data: template_configs } = await getTemplateConfigsData(token || '');
        return template_configs;
      }
      return initialValue;
    },
    [token, shouldFetch],
  );
