import Button from 'components/Button';
import DatePicker from 'components/Form/DatePickerFormik';
import Dropdown from 'components/Form/Dropdown';
import Input from 'components/Form/Input';
import { ErrorMessage, Field, Form, Formik } from 'formik';
import { useEffect, useMemo, useState } from 'react';
import type { IntlShape } from 'react-intl';
import { FormattedMessage } from 'react-intl';

import { getCosmosId } from 'pages/InitiativePipelineCreation/components/InitiativePipelineCharacteristicsSection/utils';
import { useFetchManagementCompanyLabels } from 'redux/entities/massUpdateTemplates/hooks.js';
import { useFetchSponsorCountries } from 'redux/entities/initiativesPipeline/hooks.js';

import { modelizeInitiativeDataToApi } from 'redux/pages/InitiativePipelineCardTab/modelize';

import { TabContainer } from 'styles';
import { hasError } from 'utils/formValidation';

import {
  clientTypeOptions,
  yesNoOptions,
  currencyOptions,
  exampleForNow,
  legalFD,
  legalSFF,
  navFrequencyOptions,
  navOptions,
  productTypeOption,
  regulatoryS,
  regulatoryAuthorityOptions,
} from '../InitiativeDataCard/utils';

import Style from '../InitiativePipelineCardTab/common.style.js';

type Props = {
  intl: IntlShape,
  initiativeId: string,
  token: string,
  isTaskFormOpen?: boolean,

  // redux
  createLoading?: boolean,
  createError?: any,
  lastCreated?: any,
  createInitiativeDataRequest: (payload: any) => mixed,

  products?: any,
  fetchProducts?: () => void,

  // preset values coming from upper tab/card
  productType?: any,
  cosmosId?: any,
  nameInitiative?: any,
  managementCompany?: any,
  legalForm?: any,
};

// ─── Layout helpers ──────────────────────────────────────────────────────────

const Section = ({ title, children }: any) => (
  <div style={{ marginBottom: 24 }}>
    <div style={{ marginLeft: 30, marginRight: 30 }}>
      <h3 style={{ margin: '20px 0' }}>{title}</h3>
      <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 16 }}>{children}</div>
    </div>
  </div>
);

const FieldWrap = ({ children }: any) => <div style={{ minWidth: 0 }}>{children}</div>;

// ─── Main ────────────────────────────────────────────────────────────────────

export default function InitiativeDataForm(props: Props) {
  const {
    intl,
    initiativeId,
    token,
    createInitiativeDataRequest,
    createLoading,
    createError,
    lastCreated,

    products,
    fetchProducts,

    productType,
    cosmosId,
    nameInitiative,
    managementCompany,
    legalForm,
  } = props;

  const [saveSuccess, setSaveSuccess] = useState(false);

  useEffect(() => {
    if (lastCreated && !createLoading && !createError) {
      setSaveSuccess(true);
      setTimeout(() => setSaveSuccess(false), 3000);
    }
  }, [lastCreated, createLoading, createError]);

  // ── Sponsor countries ──────────────────────────────────────────────────────
  const [sponsorCountries, setSponsorCountries] = useState([]);
  const { value: sponsor_countries } = useFetchSponsorCountries(token, true, null) || {};

  useEffect(() => {
    if (sponsor_countries) {
      const uniqueCountries = [...new Set(sponsor_countries)].sort();
      setSponsorCountries(uniqueCountries.map((country) => ({ value: country, label: country })));
    }
  }, [sponsor_countries]);

  // ── Management companies ───────────────────────────────────────────────────
  const [managementCompanies, setManagementCompanies] = useState([]);
  const { value: mgmtCompLabels } = useFetchManagementCompanyLabels(token, true, null) || {};

  useEffect(() => {
    if (mgmtCompLabels) {
      const uniqueMgmtComps = [...new Set(mgmtCompLabels)].sort();
      setManagementCompanies(uniqueMgmtComps.map((comp) => ({ value: comp, label: comp })));
    }
  }, [mgmtCompLabels]);

  // ── Products / COSMOS ID ───────────────────────────────────────────────────
  useEffect(() => {
    if (fetchProducts) fetchProducts();
  }, [fetchProducts]);

  const cosmosIdOptions = useMemo(() => getCosmosId(products), [products]);

  // ── Helpers ────────────────────────────────────────────────────────────────
  const toDateOrNull = (v: any) => {
    if (!v) return null;
    const d = new Date(v);
    return Number.isNaN(d.getTime()) ? null : d.toISOString().slice(0, 10); // YYYY-MM-DD
  };

  // ── Initial values aligned with InitiativeDataCard ─────────────────────────
  const initialValues = {
    idInitiative: initiativeId, // important: matches card wrap usage usually

    // Client
    salesforceIdOpportunity: '',
    clientDescription: '',
    clientName: '',
    clientType: '', // dropdown option
    existingHoldings: yesNoOptions.find((o) => o.value === false),
    rfp: '',
    implementationDate: '', // date
    amlKycCompleted: '',
    conflictOfInterest: yesNoOptions.find((o) => o.value === false),

    // Product
    cosmosIdData: cosmosId || '', // dropdown option
    nameData: nameInitiative || '',
    productNameData: nameInitiative || '',
    leadWalletManagerName: '', // dropdown option
    leadWalletManagerTeam: '', // dropdown option
    locateManagerWallet: '',
    aum: '',
    aumExpected: '',

    shareclassId: '',
    shareclassName: '',
    currency: currencyOptions?.find?.((o) => o.value === 'EUR') || '',

    hedging: yesNoOptions.find((o) => o.value === false),
    caproDistri: '',
    benchmark: '',

    instrumentsDetails: '',
    investmentStrategyGuidelines: '',
    additionalLicenceNeeded: yesNoOptions.find((o) => o.value === false),

    productTypeData: productType || '', // dropdown option
    legalFormData: legalForm || '', // dropdown option
    legalStructure: '', // dropdown option
    regulatoryStatus: '', // dropdown option
    countryOfDomiciliation: '', // dropdown option
    regulatoryAuthority: '', // dropdown option
    managementCompanyData: managementCompany || '', // dropdown option
    investmentManagement: '',
    investmentManagementDelegated: '',

    commentsLegalAndCompliance: '',

    // Operations
    standardService: yesNoOptions.find((o) => o.value === false),
    specificServiceDesc: '',
    nav: '', // dropdown
    subscription: '',
    navFrequency: '', // dropdown

    // Business case
    feesDesc: '',
    commentsBusiness: '',
  };

  const validate = (_values: any) => {
    const errors: any = {};
    // si tu veux remettre des champs obligatoires, on le fait après
    return errors;
  };

  const onSubmit = async (values: any, { setSubmitting }: any) => {
    try {
      setSaveSuccess(false);

      const normalizedValues = {
        ...values,

        // normalisation date
        implementationDate: values.implementationDate ? toDateOrNull(values.implementationDate) : null,

        // safety: si certains Dropdown peuvent être '', on garde '' (modelize gère généralement)
        // sinon mets null si ton modelize préfère null
      };

      const newInitiative = modelizeInitiativeDataToApi(normalizedValues);

      await createInitiativeDataRequest({
        newInitiative,
        token,
      });
    } finally {
      setSubmitting(false);
    }
  };

  return (
    <Style.Container>
      <div>
        <TabContainer>
          <Formik initialValues={initialValues} onSubmit={onSubmit} validate={validate} enableReinitialize>
            {({ errors, touched, isSubmitting }) => (
              <Form>
                {saveSuccess && (
                  <div style={{ marginBottom: 12, padding: 10, borderRadius: 6 }}>
                    <strong>Saved successfully ✅</strong>
                  </div>
                )}

                <Section title="Client">
                  <FieldWrap>
                    <Field
                      name="salesforceIdOpportunity"
                      component={Input}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.SALESFORCE_ID_OPPORTUNITY' })}
                      hasError={hasError(errors, touched, 'salesforceIdOpportunity')}
                    />
                    <ErrorMessage name="salesforceIdOpportunity" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="clientName"
                      component={Input}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.CLIENT_NAME' })}
                      hasError={hasError(errors, touched, 'clientName')}
                    />
                    <ErrorMessage name="clientName" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="clientDescription"
                      component={Input}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.CLIENT_DESCRIPTION' })}
                      hasError={hasError(errors, touched, 'clientDescription')}
                    />
                    <ErrorMessage name="clientDescription" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="clientType"
                      component={Dropdown}
                      options={clientTypeOptions}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.CLIENT_TYPE' })}
                      hasError={hasError(errors, touched, 'clientType')}
                    />
                    <ErrorMessage name="clientType" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="existingHoldings"
                      component={Dropdown}
                      options={yesNoOptions}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.EXISTING_HOLDINGS' })}
                      isClearable={false}
                      hasError={hasError(errors, touched, 'existingHoldings')}
                    />
                    <ErrorMessage name="existingHoldings" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="rfp"
                      component={Input}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.RFP' })}
                      hasError={hasError(errors, touched, 'rfp')}
                    />
                    <ErrorMessage name="rfp" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="implementationDate"
                      component={DatePicker}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.IMPLEMENTATION_DATE' })}
                      hasError={hasError(errors, touched, 'implementationDate')}
                    />
                    <ErrorMessage name="implementationDate" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="amlKycCompleted"
                      component={Input}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.AML_KYC_COMPLETED' })}
                      hasError={hasError(errors, touched, 'amlKycCompleted')}
                    />
                    <ErrorMessage name="amlKycCompleted" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="conflictOfInterest"
                      component={Dropdown}
                      options={yesNoOptions}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.CONFLICT_OF_INTEREST' })}
                      isClearable={false}
                      hasError={hasError(errors, touched, 'conflictOfInterest')}
                    />
                    <ErrorMessage name="conflictOfInterest" component="div" />
                  </FieldWrap>
                </Section>

                <Section title="Product">
                  <FieldWrap>
                    <Field
                      name="cosmosIdData"
                      component={Dropdown}
                      options={cosmosIdOptions}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.COSMOS_ID' })}
                      hasError={hasError(errors, touched, 'cosmosIdData')}
                    />
                    <ErrorMessage name="cosmosIdData" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="productNameData"
                      component={Input}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.PRODUCT_NAME_DATA' })}
                      hasError={hasError(errors, touched, 'productNameData')}
                    />
                    <ErrorMessage name="productNameData" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="leadWalletManagerName"
                      component={Dropdown}
                      options={exampleForNow}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.LEAD_WALLET_MANAGER_NAME' })}
                      hasError={hasError(errors, touched, 'leadWalletManagerName')}
                    />
                    <ErrorMessage name="leadWalletManagerName" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="leadWalletManagerTeam"
                      component={Dropdown}
                      options={exampleForNow}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.LEAD_WALLET_MANAGER_TEAM' })}
                      hasError={hasError(errors, touched, 'leadWalletManagerTeam')}
                    />
                    <ErrorMessage name="leadWalletManagerTeam" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="locateManagerWallet"
                      component={Input}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.LOCATE_MANAGER_WALLET' })}
                      hasError={hasError(errors, touched, 'locateManagerWallet')}
                    />
                    <ErrorMessage name="locateManagerWallet" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="aum"
                      component={Input}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.AUM' })}
                      hasError={hasError(errors, touched, 'aum')}
                    />
                    <ErrorMessage name="aum" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="shareclassId"
                      component={Input}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.SHARECLASS_ID' })}
                      hasError={hasError(errors, touched, 'shareclassId')}
                    />
                    <ErrorMessage name="shareclassId" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="shareclassName"
                      component={Input}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.SHARECLASS_NAME' })}
                      hasError={hasError(errors, touched, 'shareclassName')}
                    />
                    <ErrorMessage name="shareclassName" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="currency"
                      component={Dropdown}
                      options={currencyOptions}
                      isClearable={false}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.CURRENCY' })}
                      hasError={hasError(errors, touched, 'currency')}
                    />
                    <ErrorMessage name="currency" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="hedging"
                      component={Dropdown}
                      options={yesNoOptions}
                      isClearable={false}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.HEDGING' })}
                      hasError={hasError(errors, touched, 'hedging')}
                    />
                    <ErrorMessage name="hedging" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="caproDistri"
                      component={Input}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.CAPRO_DISTRI' })}
                      hasError={hasError(errors, touched, 'caproDistri')}
                    />
                    <ErrorMessage name="caproDistri" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="benchmark"
                      component={Input}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.BENCHMARK' })}
                      hasError={hasError(errors, touched, 'benchmark')}
                    />
                    <ErrorMessage name="benchmark" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="instrumentsDetails"
                      component={Input}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.INSTRUMENTS_DETAILS' })}
                      hasError={hasError(errors, touched, 'instrumentsDetails')}
                    />
                    <ErrorMessage name="instrumentsDetails" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="investmentStrategyGuidelines"
                      component={Input}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.INVESTMENT_STRATEGY_GUIDELINES' })}
                      hasError={hasError(errors, touched, 'investmentStrategyGuidelines')}
                    />
                    <ErrorMessage name="investmentStrategyGuidelines" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="additionalLicenceNeeded"
                      component={Dropdown}
                      options={yesNoOptions}
                      isClearable={false}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.ADDITIONAL_LICENCE_NEEDED' })}
                      hasError={hasError(errors, touched, 'additionalLicenceNeeded')}
                    />
                    <ErrorMessage name="additionalLicenceNeeded" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="productTypeData"
                      component={Dropdown}
                      options={productTypeOption}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.PRODUCT_TYPE' })}
                      hasError={hasError(errors, touched, 'productTypeData')}
                    />
                    <ErrorMessage name="productTypeData" component="div" />
                  </FieldWrap>
                </Section>

                <Section title="Legal and compliance">
                  <FieldWrap>
                    <Field
                      name="legalFormData"
                      component={Dropdown}
                      options={legalFD}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.LEGAL_FORM' })}
                      hasError={hasError(errors, touched, 'legalFormData')}
                    />
                    <ErrorMessage name="legalFormData" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="legalStructure"
                      component={Dropdown}
                      options={legalSFF}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.LEGAL_STRUCTURE' })}
                      hasError={hasError(errors, touched, 'legalStructure')}
                    />
                    <ErrorMessage name="legalStructure" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="regulatoryStatus"
                      component={Dropdown}
                      options={regulatoryS}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.REGULATORY_STATUS' })}
                      hasError={hasError(errors, touched, 'regulatoryStatus')}
                    />
                    <ErrorMessage name="regulatoryStatus" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="countryOfDomiciliation"
                      component={Dropdown}
                      options={sponsorCountries}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.COUNTRY_OF_DOMICILIATION' })}
                      hasError={hasError(errors, touched, 'countryOfDomiciliation')}
                    />
                    <ErrorMessage name="countryOfDomiciliation" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="regulatoryAuthority"
                      component={Dropdown}
                      options={regulatoryAuthorityOptions}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.REGULATORY_AUTHORITY' })}
                      hasError={hasError(errors, touched, 'regulatoryAuthority')}
                    />
                    <ErrorMessage name="regulatoryAuthority" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="managementCompanyData"
                      component={Dropdown}
                      options={managementCompanies}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.MANAGEMENT_COMPANY' })}
                      hasError={hasError(errors, touched, 'managementCompanyData')}
                    />
                    <ErrorMessage name="managementCompanyData" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="investmentManagement"
                      component={Input}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.INVESTMENT_MANAGEMENT' })}
                      hasError={hasError(errors, touched, 'investmentManagement')}
                    />
                    <ErrorMessage name="investmentManagement" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="investmentManagementDelegated"
                      component={Input}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.INVESTMENT_MANAGEMENT_DELEGATED' })}
                      hasError={hasError(errors, touched, 'investmentManagementDelegated')}
                    />
                    <ErrorMessage name="investmentManagementDelegated" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="commentsLegalAndCompliance"
                      component={Input}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.COMMENTS_LEGAL_AND_COMPLIANCE' })}
                      hasError={hasError(errors, touched, 'commentsLegalAndCompliance')}
                    />
                    <ErrorMessage name="commentsLegalAndCompliance" component="div" />
                  </FieldWrap>
                </Section>

                <Section title="Operations">
                  <FieldWrap>
                    <Field
                      name="standardService"
                      component={Dropdown}
                      options={yesNoOptions}
                      isClearable={false}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.STANDARD_SERVICE' })}
                      hasError={hasError(errors, touched, 'standardService')}
                    />
                    <ErrorMessage name="standardService" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="specificServiceDesc"
                      component={Input}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.SPECIFIC_SERVICE_DESC' })}
                      hasError={hasError(errors, touched, 'specificServiceDesc')}
                    />
                    <ErrorMessage name="specificServiceDesc" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="nav"
                      component={Dropdown}
                      options={navOptions}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.NAV' })}
                      hasError={hasError(errors, touched, 'nav')}
                    />
                    <ErrorMessage name="nav" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="subscription"
                      component={Input}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.SUBSCRIPTION' })}
                      hasError={hasError(errors, touched, 'subscription')}
                    />
                    <ErrorMessage name="subscription" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="navFrequency"
                      component={Dropdown}
                      options={navFrequencyOptions}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.NAV_FREQUENCY' })}
                      hasError={hasError(errors, touched, 'navFrequency')}
                    />
                    <ErrorMessage name="navFrequency" component="div" />
                  </FieldWrap>
                </Section>

                <Section title="Business Case">
                  <FieldWrap>
                    <Field
                      name="aumExpected"
                      component={Input}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.AUM_EXPECTED' })}
                      hasError={hasError(errors, touched, 'aumExpected')}
                    />
                    <ErrorMessage name="aumExpected" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="feesDesc"
                      component={Input}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.FEES_DESC' })}
                      hasError={hasError(errors, touched, 'feesDesc')}
                    />
                    <ErrorMessage name="feesDesc" component="div" />
                  </FieldWrap>

                  <FieldWrap>
                    <Field
                      name="commentsBusiness"
                      component={Input}
                      label={intl.formatMessage({ id: 'INITIATIVE_DATA.COMMENTS_BUSINESS' })}
                      hasError={hasError(errors, touched, 'commentsBusiness')}
                    />
                    <ErrorMessage name="commentsBusiness" component="div" />
                  </FieldWrap>

                  <div />
                </Section>

                {createError ? (
                  <div style={{ marginBottom: 12, marginLeft: 30, marginRight: 30 }}>
                    <strong>
                      <FormattedMessage id="FORM.SUBMIT_ERROR" defaultMessage="Submit error" />
                    </strong>{' '}
                    {typeof createError === 'string' ? createError : JSON.stringify(createError)}
                  </div>
                ) : null}

                {/* Submit button – aligned with InitiativeDataCard usage */}
                <div style={{ marginRight: 30, display: 'flex', justifyContent: 'flex-end', gap: 12 }}>
                  <Button
                    type="submit"
                    disabled={createLoading || isSubmitting}
                    label={
                      <FormattedMessage
                        id="INITIATIVE_DATA.CREATE_INITIATIVE_DATA"
                        defaultMessage="Create Initiative Data"
                      />
                    }
                  >
                    <FormattedMessage id="FORM.SAVE" defaultMessage="Save" />
                  </Button>
                </div>
              </Form>
            )}
          </Formik>
        </TabContainer>
      </div>
    </Style.Container>
  );
}
