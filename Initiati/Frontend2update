            <div />
          </SubSection>

          <SubSection
            title={<FormattedMessage id="INITIATIVE_DATA.SUBSECTION.MANAGEMENT_TEAM" defaultMessage="Management team" />}
          >
            {/* Portfolio manager team (Text) */}
            <SmartField
              isEditing={isEditing}
