              intl={intl}
              name="cosmosIdData"
              labelId="INITIATIVE_DATA.COSMOS_ID"
              component={CommonStyle.Dropdown}
              options={cosmosIdOptions}
              data={initiativeData}
              displaySnakeKey="cosmos_id_data"
