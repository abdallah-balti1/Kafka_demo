const Section = ({ title, children }: any) => (
  <div style={{ marginBottom: 28 }}>
    <div style={{ marginLeft: 30, marginRight: 30 }}>
      <h3 style={{ margin: '18px 0 14px 0', fontSize: 18, fontWeight: 600 }}>{title}</h3>
      <div style={{ display: 'flex', flexDirection: 'column', gap: 14 }}>{children}</div>
    </div>
  </div>
);

const SubSection = ({ title, children }: any) => (
  <div style={{ padding: '14px 16px', border: '1px solid rgba(0,0,0,0.08)', borderRadius: 10 }}>
    <div style={{ marginBottom: 10, fontSize: 14, fontWeight: 600, opacity: 0.85 }}>{title}</div>
    <div
      style={{
        display: 'grid',
        gridTemplateColumns: 'repeat(2, minmax(0, 1fr))',
        columnGap: 22,
        rowGap: 16,
        alignItems: 'start',
      }}
    >
      {children}
    </div>
  </div>
);

const FieldWrap = ({ children }: any) => <div style={{ minWidth: 0 }}>{children}</div>;

const Label = ({ id }: { id: string }) => (
  <div
    style={{
      fontSize: 13,
      letterSpacing: 0.2,
      opacity: 0.75,
      marginBottom: 6,
      fontWeight: 600,
    }}
  >
    <FormattedMessage id={id} />
  </div>
);

const formatAnyValue = (v: any) => {
  if (v === null || v === undefined || v === '') return '-';
  if (typeof v === 'boolean') return v ? 'Yes' : 'No';

  // Common dropdown shapes: {label, value}
  if (typeof v === 'object') {
    if (Array.isArray(v)) return v.map(formatAnyValue).join(', ');
    if (v.label !== undefined && v.label !== null && v.label !== '') return String(v.label);
    if (v.value !== undefined && v.value !== null && v.value !== '') return String(v.value);
    try {
      return JSON.stringify(v);
    } catch (e) {
      return String(v);
    }
  }

  return String(v);
};

const Value = ({ children }: any) => (
  <div style={{ fontSize: 14, lineHeight: '18px', wordBreak: 'break-word' }}>
    {formatAnyValue(children)}
  </div>
);

const pick = (obj: any, camelKey: string, snakeKey: string) => {
  if (!obj) return undefined;
  const camel = obj[camelKey];
  if (camel !== undefined && camel !== null && camel !== '') return camel;
  return obj[snakeKey];
};

const DisplayField = ({
  labelId,
  camelKey,
  snakeKey,
  data,
}: {
  labelId: string,
  camelKey: string,
  snakeKey: string,
  data: any,
}) => (
  <FieldWrap>
    <Label id={labelId} />
    <Value>{pick(data, camelKey, snakeKey)}</Value>
  </FieldWrap>
);

// "Long text" helper: still uses CommonStyle.Input, but passes multiline hints (ignored if not supported).
const LongTextProps = { multiline: true, rows: 4 };

const SmartField = ({
  isEditing,
  intl,
  name,
  labelId,
  component,
  options,
  validate,
  displayCamelKey,
  displaySnakeKey,
  data,
  fieldProps,
}: any) => (
  <FieldWrap>
    {isEditing ? (
      <Field
        name={name}
        component={component}
        options={options}
        validate={validate}
        label={intl.formatMessage({ id: labelId })}
        {...(fieldProps || {})}
      />
    ) : (
      <DisplayField
        labelId={labelId}
        camelKey={displayCamelKey || name}
        snakeKey={displaySnakeKey || name}
        data={data}
      />
    )}
  </FieldWrap>
);

