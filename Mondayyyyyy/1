export function getTemplate(templateId: string, token: string) {
  const requestURL = `${config.INITIATIVE_API_URL}/templates/${templateId}`;
  return request(requestURL, {
    method: 'GET',
    headers: {
      authorization: `Bearer ${token}`,
    },
  });
}





