export function* getOneInitiativeSaga(action): Saga<> {
  try {
    const initiativeId = action.payload?.initiativeId;
    const response = yield call(authenticatedCall, getInitiative, initiativeId);
    const initiative = modelizeInitiativeFromApi(response.data[0]);

    const globalRatingsResponse = yield call(authenticatedCall, getGlobalRatings, initiativeId);
    initiative.global_ratings = globalRatingsResponse?.data?.global_ratings || [];

    // ✅ AJOUTER ces 4 lignes
    if (initiative.templateId) {
      const templateResponse = yield call(authenticatedCall, getTemplate, initiative.templateId);
      initiative.template_name = templateResponse?.data?.name || null;
    }

    yield put(getOneInitiativePipelineSuccess(initiative));
  } catch (error) {
    yield call(handleAPIExceptions, error);
    yield put(getOneInitiativePipelineFailure(error));
  }
}


