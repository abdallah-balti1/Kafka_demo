// @flow
import Button from 'components/Button';
import { ErrorMessage, Field, Form, Formik } from 'formik';
import { useEffect, useMemo, useState } from 'react';
import type { IntlShape } from 'react-intl';
import { FormattedMessage } from 'react-intl';

import { getCosmosId } from 'pages/InitiativePipelineCreation/components/InitiativePipelineCharacteristicsSection/utils';
import { modelizeInitiativeDataToApi } from 'redux/pages/InitiativePipelineCardTab/modelize';
import { useFetchManagementCompanyLabels } from 'redux/entities/massUpdateTemplates/hooks.js';
import { useFetchSponsorCountries } from 'redux/entities/initiativesPipeline/hooks.js';
import { hasError } from 'utils/formValidation';
import {
  yesNoOptions,
  legalFD,
  legalSFF,
  regulatoryS,
} from '../InitiativeDataCard/utils';

import Style from './common.style';

// ─── Types ────────────────────────────────────────────────────────────────────

type Props = {
  intl: IntlShape,
  initiativeId: string,
  token: string,
  isTaskFormOpen?: boolean,

  // redux
  createLoading?: boolean,
  createError?: any,
  lastCreated?: any,
  createInitiativeDataRequest: (payload: any) => mixed,
  getInitiativeData: (initiativeId: string) => any,

  products?: any,
  fetchProducts?: () => void,
  cosmosId?: any,
  nameInitiative?: any,
  managementCompany?: any,
  legalForm?: any,
};

// ─── Layout components ────────────────────────────────────────────────────────

const Section = ({ title, children }: any) => (
  <div style={{ marginBottom: 28, marginLeft: 30, marginRight: 30 }}>
    <Style.SectionTitle>{title}</Style.SectionTitle>
    <div style={{ display: 'flex', flexDirection: 'column', gap: 14 }}>{children}</div>
  </div>
);

const SubSection = ({ title, children }: any) => (
  <Style.SubSectionCard>
    <Style.SubSectionTitle>{title}</Style.SubSectionTitle>
    <Style.FieldGrid>{children}</Style.FieldGrid>
  </Style.SubSectionCard>
);

// ─── Main component ───────────────────────────────────────────────────────────

export default function InitiativeDataForm(props: Props) {
  const {
    intl,
    initiativeId,
    token,
    createInitiativeDataRequest,
    getInitiativeData,
    createLoading,
    createError,
    products,
    cosmosId,
    lastCreated,
    nameInitiative,
    managementCompany,
    legalForm,
    fetchProducts,
  } = props;

  const [saveSuccess, setSaveSuccess] = useState(false);

  // ── Auto-refresh InitiativeDataCard after successful submit ──────────────────
  useEffect(() => {
    if (lastCreated && !createLoading && !createError) {
      setSaveSuccess(true);
      if (getInitiativeData && initiativeId) {
        getInitiativeData(String(initiativeId));
      }
      setTimeout(() => setSaveSuccess(false), 3000);
    }
  }, [lastCreated, createLoading, createError]);

  // ── Sponsor countries ────────────────────────────────────────────────────────
  const [sponsorCountries, setSponsorCountries] = useState([]);
  const { value: sponsor_countries } = useFetchSponsorCountries(token, true, null) || {};

  useEffect(() => {
    if (sponsor_countries) {
      const uniqueCountries = [...new Set(sponsor_countries)].sort();
      setSponsorCountries(uniqueCountries.map((country) => ({ value: country, label: country })));
    }
  }, [sponsor_countries]);

  // ── Management companies ─────────────────────────────────────────────────────
  const [managementCompanies, setManagementCompanies] = useState([]);
  const { value: mgmtCompLabels } = useFetchManagementCompanyLabels(token, true, null) || {};

  useEffect(() => {
    if (mgmtCompLabels) {
      const uniqueMgmtComps = [...new Set(mgmtCompLabels)].sort();
      setManagementCompanies(uniqueMgmtComps.map((comp) => ({ value: comp, label: comp })));
    }
  }, [mgmtCompLabels]);

  // ── Products / COSMOS ID ─────────────────────────────────────────────────────
  useEffect(() => {
    if (fetchProducts) fetchProducts();
  }, [fetchProducts]);

  const cosmosIdOptions = useMemo(() => getCosmosId(products), [products]);

  // ── Initial values ───────────────────────────────────────────────────────────
  const initialValues = {
    initiativeId,

    // PRODUCT / Description
    productNameData: nameInitiative,          // → product_name_data
    nameData: nameInitiative,                 // → name_data
    implementationDate: '',                   // → implementation_date
    cosmosIdData: cosmosId,                   // → cosmos_id_data (pickValue)

    // PRODUCT / Management team
    leadWalletManagerTeam: '',                // → lead_wallet_manager_team (pickValue)
    leadWalletManagerName: '',                // → lead_wallet_manager_name (pickValue)

    // PRODUCT / Structure
    legalFormData: legalForm,                 // → legal_form_data (pickValue)
    managementCompanyData: managementCompany, // → management_company_data (raw)
    legalStructure: '',                       // → legal_structure (pickValue)
    investmentManagement: '',                 // → investment_management
    investmentManagementDelegated: '',        // → investment_management_delegated
    shareclassName: '',                       // → shareclass_name
    regulatoryStatus: '',                     // → regulatory_status (pickValue)
    countryOfDomiciliation: '',               // → country_of_domiciliation (pickValue)
    additionalLicenceNeeded: '',              // → additional_licence_needed (pickBool)
    investmentStrategyGuidelines: '',         // → investment_strategy_guidelines
    feesDesc: '',                             // → fees_desc

    // PRODUCT / Benchmark
    benchmark: '',                            // → benchmark (pickBool)

    // PRODUCT / Portfolio composition
    instrumentsDetails: '',                   // → instruments_details

    // BUSINESS CASE
    aumExpected: '',                          // → aum_expected
    commentsBusiness: '',                     // → comments_buisness

    // CLIENT
    salesforceIdOpportunity: '',              // → salesforce_id_opportunity
    clientName: '',                           // → client_name
    clientDescription: '',                    // → client_description
    clientType: '',                           // → client_type
    existingHoldings: '',                     // → existing_holdings
    rfp: '',                                  // → rfp

    // OPERATIONS
    standardService: yesNoOptions.find((o) => o.value === false), // → standard_service (pickBool)
    specificServiceDesc: '',                  // → specific_service_desc
  };

  // ── Helpers ──────────────────────────────────────────────────────────────────
  const validate = (values: any) => {
    const errors: any = {};
    return errors;
  };

  const toDateOrNull = (v: any) => {
    if (!v) return null;
    const d = new Date(v);
    return Number.isNaN(d.getTime()) ? null : d.toISOString().slice(0, 10);
  };

  // ── Submit ───────────────────────────────────────────────────────────────────
  const onSubmit = async (values: any, { setSubmitting }: any) => {
    try {
      setSaveSuccess(false);

      const normalizedValues = {
        ...values,
        // Pre-resolve fields that modelize uses raw (not via pickValue/pickBool)
        managementCompanyData: values.managementCompanyData?.value ?? values.managementCompanyData ?? null,
        standardService: values.standardService?.value ?? values.standardService ?? null,
        implementationDate: values.implementationDate ? toDateOrNull(values.implementationDate) : null,
      };

      const newInitiative = modelizeInitiativeDataToApi(normalizedValues);

      await createInitiativeDataRequest({
        newInitiative,
        token,
      });

      setSaveSuccess(true);
      setTimeout(() => setSaveSuccess(false), 3000);

      // Auto-refresh the InitiativeDataCard with the newly saved data
      if (getInitiativeData && initiativeId) {
        getInitiativeData(String(initiativeId));
      }
    } finally {
      setSubmitting(false);
    }
  };

  // ── Render ───────────────────────────────────────────────────────────────────
  return (
    <Style.Container>
      <Formik initialValues={initialValues} onSubmit={onSubmit} validate={validate} enableReinitialize>
        {({ errors, touched, isSubmitting }) => (
          <Form>

            {/* Success banner */}
            {saveSuccess && (
              <Style.SuccessBanner>
                <FormattedMessage id="FORM.SAVED_SUCCESSFULLY" defaultMessage="Saved successfully ✅" />
              </Style.SuccessBanner>
            )}

            {/* ════════════════════════════════════════════════════════
                SECTION: PRODUCT
            ════════════════════════════════════════════════════════ */}
            <Section title={<FormattedMessage id="INITIATIVE_DATA.SECTION.PRODUCT" defaultMessage="Product" />}>

              {/* Description */}
              <SubSection
                title={
                  <FormattedMessage id="INITIATIVE_DATA.SUBSECTION.DESCRIPTION" defaultMessage="Description" />
                }
              >
                <Style.FieldWrap>
                  <Field
                    name="productNameData"
                    component={Style.Input}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.PRODUCT_NAME_DATA' })}
                    hasError={hasError(errors, touched, 'productNameData')}
                  />
                  <ErrorMessage name="productNameData" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>

                <Style.FieldWrap>
                  <Field
                    name="implementationDate"
                    component={Style.DatePicker}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.IMPLEMENTATION_DATE' })}
                    hasError={hasError(errors, touched, 'implementationDate')}
                  />
                  <ErrorMessage name="implementationDate" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>

                <Style.FieldWrap>
                  <Field
                    name="cosmosIdData"
                    component={Style.Dropdown}
                    options={cosmosIdOptions}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.COSMOS_ID' })}
                    hasError={hasError(errors, touched, 'cosmosIdData')}
                  />
                  <ErrorMessage name="cosmosIdData" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>

                <div />
              </SubSection>

              {/* Management team */}
              <SubSection
                title={
                  <FormattedMessage
                    id="INITIATIVE_DATA.SUBSECTION.MANAGEMENT_TEAM"
                    defaultMessage="Management team"
                  />
                }
              >
                <Style.FieldWrap>
                  <Field
                    name="leadWalletManagerTeam"
                    component={Style.Input}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.LEAD_WALLET_MANAGER_TEAM' })}
                    hasError={hasError(errors, touched, 'leadWalletManagerTeam')}
                  />
                  <ErrorMessage name="leadWalletManagerTeam" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>

                <Style.FieldWrap>
                  <Field
                    name="leadWalletManagerName"
                    component={Style.Input}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.LEAD_WALLET_MANAGER_NAME' })}
                    hasError={hasError(errors, touched, 'leadWalletManagerName')}
                  />
                  <ErrorMessage name="leadWalletManagerName" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>
              </SubSection>

              {/* Structure */}
              <SubSection
                title={<FormattedMessage id="INITIATIVE_DATA.SUBSECTION.STRUCTURE" defaultMessage="Structure" />}
              >
                <Style.FieldWrap>
                  <Field
                    name="legalFormData"
                    component={Style.Dropdown}
                    options={[legalFD, legalSFF]}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.LEGAL_FORM' })}
                    hasError={hasError(errors, touched, 'legalFormData')}
                  />
                  <ErrorMessage name="legalFormData" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>

                <Style.FieldWrap>
                  <Field
                    name="managementCompanyData"
                    component={Style.Dropdown}
                    options={managementCompanies}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.MANAGEMENT_COMPANY' })}
                    hasError={hasError(errors, touched, 'managementCompanyData')}
                  />
                  <ErrorMessage name="managementCompanyData" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>

                <Style.FieldWrap>
                  <Field
                    name="legalStructure"
                    component={Style.Input}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.LEGAL_STRUCTURE' })}
                    hasError={hasError(errors, touched, 'legalStructure')}
                  />
                  <ErrorMessage name="legalStructure" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>

                <Style.FieldWrap>
                  <Field
                    name="investmentManagementDelegated"
                    component={Style.Input}
                    multiline
                    rows={4}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.INVESTMENT_MANAGEMENT_DELEGATED' })}
                    hasError={hasError(errors, touched, 'investmentManagementDelegated')}
                  />
                  <ErrorMessage name="investmentManagementDelegated" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>

                <Style.FieldWrap>
                  <Field
                    name="shareclassName"
                    component={Style.Input}
                    multiline
                    rows={4}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.SHARECLASS_OFFER' })}
                    hasError={hasError(errors, touched, 'shareclassName')}
                  />
                  <ErrorMessage name="shareclassName" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>

                <Style.FieldWrap>
                  <Field
                    name="regulatoryStatus"
                    component={Style.Dropdown}
                    options={regulatoryS}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.REGULATORY_STATUS' })}
                    hasError={hasError(errors, touched, 'regulatoryStatus')}
                  />
                  <ErrorMessage name="regulatoryStatus" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>

                <Style.FieldWrap>
                  <Field
                    name="countryOfDomiciliation"
                    component={Style.Dropdown}
                    options={sponsorCountries}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.COUNTRY_OF_DOMICILIATION' })}
                    hasError={hasError(errors, touched, 'countryOfDomiciliation')}
                  />
                  <ErrorMessage name="countryOfDomiciliation" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>

                <Style.FieldWrap>
                  <Field
                    name="additionalLicenceNeeded"
                    component={Style.Input}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.ADDITIONAL_LICENCE_NEEDED' })}
                    hasError={hasError(errors, touched, 'additionalLicenceNeeded')}
                  />
                  <ErrorMessage name="additionalLicenceNeeded" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>

                <Style.FieldWrap>
                  <Field
                    name="investmentStrategyGuidelines"
                    component={Style.Input}
                    multiline
                    rows={4}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.INVESTMENT_STRATEGY_GUIDELINES' })}
                    hasError={hasError(errors, touched, 'investmentStrategyGuidelines')}
                  />
                  <ErrorMessage name="investmentStrategyGuidelines" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>

                <Style.FieldWrap>
                  <Field
                    name="feesDesc"
                    component={Style.Input}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.FEES_DESC' })}
                    hasError={hasError(errors, touched, 'feesDesc')}
                  />
                  <ErrorMessage name="feesDesc" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>
              </SubSection>

              {/* Benchmark */}
              <SubSection
                title={<FormattedMessage id="INITIATIVE_DATA.SUBSECTION.BENCHMARK" defaultMessage="Benchmark" />}
              >
                <Style.FieldWrap>
                  <Field
                    name="benchmark"
                    component={Style.Input}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.BENCHMARK' })}
                    hasError={hasError(errors, touched, 'benchmark')}
                  />
                  <ErrorMessage name="benchmark" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>

                <div />
              </SubSection>

              {/* Portfolio composition */}
              <SubSection
                title={
                  <FormattedMessage
                    id="INITIATIVE_DATA.SUBSECTION.PORTFOLIO_COMPOSITION"
                    defaultMessage="Portfolio composition"
                  />
                }
              >
                <Style.FieldWrap>
                  <Field
                    name="instrumentsDetails"
                    component={Style.Input}
                    multiline
                    rows={4}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.INSTRUMENTS_DETAILS' })}
                    hasError={hasError(errors, touched, 'instrumentsDetails')}
                  />
                  <ErrorMessage name="instrumentsDetails" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>

                <div />
              </SubSection>
            </Section>

            {/* ════════════════════════════════════════════════════════
                SECTION: BUSINESS CASE
            ════════════════════════════════════════════════════════ */}
            <Section
              title={
                <FormattedMessage id="INITIATIVE_DATA.SECTION.BUSINESS_CASE" defaultMessage="Business Case" />
              }
            >
              <SubSection
                title={<FormattedMessage id="INITIATIVE_DATA.SUBSECTION.BUSINESS" defaultMessage="Business" />}
              >
                <Style.FieldWrap>
                  <Field
                    name="aumExpected"
                    component={Style.Input}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.AUM_EXPECTED' })}
                    hasError={hasError(errors, touched, 'aumExpected')}
                  />
                  <ErrorMessage name="aumExpected" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>

                <Style.FieldWrap>
                  <Field
                    name="commentsBusiness"
                    component={Style.Input}
                    multiline
                    rows={4}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.COMMENTS_BUSINESS' })}
                    hasError={hasError(errors, touched, 'commentsBusiness')}
                  />
                  <ErrorMessage name="commentsBusiness" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>
              </SubSection>
            </Section>

            {/* ════════════════════════════════════════════════════════
                SECTION: CLIENT
            ════════════════════════════════════════════════════════ */}
            <Section title={<FormattedMessage id="INITIATIVE_DATA.SECTION.CLIENT" defaultMessage="Client" />}>
              <SubSection
                title={<FormattedMessage id="INITIATIVE_DATA.SUBSECTION.CLIENT" defaultMessage="Client" />}
              >
                <Style.FieldWrap>
                  <Field
                    name="salesforceIdOpportunity"
                    component={Style.Input}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.SALESFORCE_ID_OPPORTUNITY' })}
                    hasError={hasError(errors, touched, 'salesforceIdOpportunity')}
                  />
                  <ErrorMessage name="salesforceIdOpportunity" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>

                <Style.FieldWrap>
                  <Field
                    name="clientName"
                    component={Style.Input}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.CLIENT_NAME' })}
                    hasError={hasError(errors, touched, 'clientName')}
                  />
                  <ErrorMessage name="clientName" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>

                <Style.FieldWrap>
                  <Field
                    name="clientDescription"
                    component={Style.Input}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.CLIENT_DESCRIPTION' })}
                    hasError={hasError(errors, touched, 'clientDescription')}
                  />
                  <ErrorMessage name="clientDescription" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>

                <Style.FieldWrap>
                  <Field
                    name="clientType"
                    component={Style.Input}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.CLIENT_TYPE' })}
                    hasError={hasError(errors, touched, 'clientType')}
                  />
                  <ErrorMessage name="clientType" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>

                <Style.FieldWrap>
                  <Field
                    name="existingHoldings"
                    component={Style.Input}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.EXISTING_HOLDINGS' })}
                    hasError={hasError(errors, touched, 'existingHoldings')}
                  />
                  <ErrorMessage name="existingHoldings" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>

                <Style.FieldWrap>
                  <Field
                    name="rfp"
                    component={Style.Input}
                    multiline
                    rows={4}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.RFP' })}
                    hasError={hasError(errors, touched, 'rfp')}
                  />
                  <ErrorMessage name="rfp" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>
              </SubSection>
            </Section>

            {/* ════════════════════════════════════════════════════════
                SECTION: OPERATIONS
            ════════════════════════════════════════════════════════ */}
            <Section
              title={<FormattedMessage id="INITIATIVE_DATA.SECTION.OPERATIONS" defaultMessage="Operations" />}
            >
              <SubSection
                title={
                  <FormattedMessage id="INITIATIVE_DATA.SUBSECTION.OPERATIONS" defaultMessage="Operations" />
                }
              >
                <Style.FieldWrap>
                  <Field
                    name="standardService"
                    component={Style.Dropdown}
                    options={yesNoOptions}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.STANDARD_SERVICE' })}
                    hasError={hasError(errors, touched, 'standardService')}
                  />
                  <ErrorMessage name="standardService" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>

                <Style.FieldWrap>
                  <Field
                    name="specificServiceDesc"
                    component={Style.Input}
                    multiline
                    rows={4}
                    label={intl.formatMessage({ id: 'INITIATIVE_DATA.SPECIFIC_SERVICE_DESC' })}
                    hasError={hasError(errors, touched, 'specificServiceDesc')}
                  />
                  <ErrorMessage name="specificServiceDesc" component={Style.FieldErrorMessage} />
                </Style.FieldWrap>
              </SubSection>
            </Section>

            {/* Error banner */}
            {createError && (
              <Style.ErrorBanner>
                <strong>
                  <FormattedMessage id="FORM.SUBMIT_ERROR" defaultMessage="Submit error" />
                </strong>{' '}
                {typeof createError === 'string' ? createError : JSON.stringify(createError)}
              </Style.ErrorBanner>
            )}

            {/* Submit button */}
            <Style.FooterRow>
              <Button
                type="submit"
                disabled={createLoading || isSubmitting}
                label={
                  <FormattedMessage
                    id="INITIATIVE_DATA.CREATE_INITIATIVE_DATA"
                    defaultMessage="Create Initiative Data"
                  />
                }
              >
                <FormattedMessage id="FORM.SAVE" defaultMessage="Save" />
              </Button>
            </Style.FooterRow>

          </Form>
        )}
      </Formik>
    </Style.Container>
  );
}
