import { modelizeTeam } from 'redux/entities/teams/modelize';

export const modelizeMilestonesTargetDatesForApi = (
  targetDates: ProjectTimelineValuesType,
): ProjectTimelineValuesType => {
  const formattedTargetDates = {};
  Object.keys(targetDates).forEach(
    milestoneId => (formattedTargetDates[milestoneId] = targetDates[milestoneId] || null),
  );
  return formattedTargetDates;
};

export const modelizeKeyQuestionsImpact = (
  apiKeyQuestionsImpact: ApiKeyQuestionsImpactType,
): KeyQuestionsImpactType => ({
  addedTeams: apiKeyQuestionsImpact.added_teams.map(modelizeTeam),
  removedTeams: apiKeyQuestionsImpact.removed_teams.map(modelizeTeam),
});

const pickValue = v => {
  // dropdown react-select: {value,label}
  if (v && typeof v === 'object' && 'value' in v) return v.value;
  // si on a gardé une string directement
  if (v === '') return null;
  return v ?? null;
};

const pickBool = v => {
  const raw = pickValue(v);
  if (raw === true || raw === false) return raw;
  if (raw === 'true') return true;
  if (raw === 'false') return false;
  return null; // ou false si ton API exige un bool non-null
};

