from openpyxl.worksheet.datavalidation import DataValidation
from openpyxl.utils import get_column_letter

def create_data_validation(ws, adl_fees_data):
    """
    Validation sur 2 colonnes éditables:
    - valeur vide autorisée
    - sinon: nombre réel >= 0
    - accepte décimales avec '.' ou ','
    """

    n_rows = max(len(adl_fees_data or []), 1)
    end_row = DATA_START_ROW + n_rows - 1

    col_in = get_column_letter(NEW_ADL_IN_COLUMN)
    col_out = get_column_letter(NEW_ADL_OUT_COLUMN)

    def make_formula(anchor_cell: str) -> str:
        # On tente 2 conversions:
        # 1) '.' -> ',' (utile pour Excel FR)
        # 2) ',' -> '.' (utile si Excel attend '.')
        # Si une des 2 conversions marche et >=0 => OK
        return (
            f'OR('
            f'{anchor_cell}="",'
            f'IFERROR(VALUE(SUBSTITUTE({anchor_cell},".",","))>=0,FALSE),'
            f'IFERROR(VALUE(SUBSTITUTE({anchor_cell},",","."))>=0,FALSE)'
            f')'
        )

    def add_dv_for_column(col_letter: str):
        anchor = f"{col_letter}{DATA_START_ROW}"
        dv = DataValidation(
            type="custom",
            formula1=make_formula(anchor),
            allow_blank=True,
            showErrorMessage=True,
            errorStyle="stop",  # <-- IMPORTANT: bloque vraiment (pas juste warning)
            errorTitle=DATA_VALIDATION_ERROR_TITLE,
            error=DATA_VALIDATION_ERROR_MESSAGE,
        )
        ws.add_data_validation(dv)
        dv.add(f"{col_letter}{DATA_START_ROW}:{col_letter}{end_row}")

    add_dv_for_column(col_in)
    add_dv_for_column(col_out)
