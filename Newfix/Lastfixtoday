from datetime import date, datetime

class InitiativeDataRepository:
    """The repository for the initiative"""

    @staticmethod
    def _empty_to_none(value):
        # Convert "None", "", "null", None -> None
        if value is None:
            return None
        if isinstance(value, str):
            v = value.strip()
            if v == "" or v.lower() in {"none", "null", "undefined"}:
                return None
        return value

    @staticmethod
    def _date_or_none(value):
        value = InitiativeDataRepository._empty_to_none(value)
        if value is None:
            return None

        # If already a python date/datetime
        if isinstance(value, date) and not isinstance(value, datetime):
            return value
        if isinstance(value, datetime):
            return value.date()

        # If it's a string: accept ISO formats
        if isinstance(value, str):
            v = value.strip()
            # common cases: "2026-02-25" or "2026-02-25T00:00:00.000Z"
            try:
                return datetime.fromisoformat(v.replace("Z", "+00:00")).date()
            except Exception:
                # If format is weird, let it crash clearly
                raise ValueError(f"Invalid date format for implementation_date: {value}")

        return value
