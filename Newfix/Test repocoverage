    def test_repo_update_branches(self):
        """
        Covers update() branches:
        - not found
        - update name/order/display_name
        - update flags when not None
        - keep fields when None/empty
        """
        with self.assertRaises(EntityNotFound):
            TeamRepository.update(999999, "X", 1, "Y")

        # Update only some fields
        updated = TeamRepository.update(
            self.team2.id,
            name="FinanceUpdated",
            display_order=99,
            display_name=None,  # should keep old display_name because repo checks "if display_name:"
            is_project_user=False,
            is_initiative_user=True,
        )
        self.assertEqual(updated.name, "FinanceUpdated")
        self.assertEqual(updated.display_order, 99)
        # display_name should remain "Finance"
        self.assertEqual(updated.display_name, "Finance")
        self.assertFalse(bool(updated.is_project_user))
        self.assertTrue(bool(updated.is_initiative_user))

        # Call update with flags None => should NOT overwrite
        updated2 = TeamRepository.update(
            self.team2.id,
            name=None,
            display_order=None,
            display_name="FinanceDisplay",
            is_project_user=None,
            is_initiative_user=None,
        )
        self.assertEqual(updated2.display_name, "FinanceDisplay")
        self.assertFalse(bool(updated2.is_project_user))
        self.assertTrue(bool(updated2.is_initiative_user))

    def test_repo_update_status_toggle(self):
        # team3 starts inactive
        self.assertFalse(bool(self.team3.is_active))

        t = TeamRepository.update_status(self.team3.id)
        self.assertTrue(bool(t.is_active))

        t2 = TeamRepository.update_status(self.team3.id)
        self.assertFalse(bool(t2.is_active))

    def test_repo_update_project_user_toggle(self):
        """
        Covers update_project_user() which uses get_or_404 -> needs app context.
        """
        with server.app_context():
            before = bool(TeamRepository.get(self.team1.id).is_project_user)
            t = TeamRepository.update_project_user(self.team1.id)
            after = bool(t.is_project_user)
            self.assertNotEqual(before, after)

    def test_repo_update_initiative_user_toggle(self):
        """
        Covers update_initiative_user() which uses get_or_404 -> needs app context.
        """
        with server.app_context():
            before = bool(TeamRepository.get(self.team1.id).is_initiative_user)
            t = TeamRepository.update_initiative_user(self.team1.id)
            after = bool(t.is_initiative_user)
            self.assertNotEqual(before, after)
