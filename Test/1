"""
test/helpers.py
Helpers partagés pour tous les tests du projet FLOWR-INITIATIVE-PIPELINE.
Inspiré du pattern helpers.py de flowr-api.
"""

from db import db
from models import Initiative


# ---------------------------------------------------------------------------
# Database lifecycle
# ---------------------------------------------------------------------------

def init_database():
    """
    Initialise la base de test : tente de vider les tables,
    sinon recrée le schéma complet.
    """
    try:
        delete_all_data()
    except Exception:
        db.create_all()


def delete_all_data():
    """Vide toutes les tables dans le bon ordre (FK awareness)."""
    reset_table(Initiative)
    db.session.commit()


def reset_table(model):
    """
    Truncate ou delete selon que le model a un __table__ SQLAlchemy.
    """
    from sqlalchemy.sql.expression import text, delete

    if hasattr(model, "__table__"):
        tablename = model.__tablename__
        db.session.execute(
            text(f"TRUNCATE TABLE {tablename} RESTART IDENTITY CASCADE")
        )
    else:
        db.session.execute(delete(model))


