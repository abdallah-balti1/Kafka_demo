# Seed data
# ---------------------------------------------------------------------------

def insert_initiative(
    name="Test Initiative",
    summary="A test summary",
    product_type="EQUITY",
    initiative_type="INTERNAL",
    sponsor="Sponsor SA",
    sponsor_country="FR",
    asset_class="EQUITY",
    management_company="Flowr",
    committee_date=None,
    distribution_channel="DIRECT",
    governance_required="NO",
    legal_form="FCP",
    initiative_owner="owner@flowr.com",
    cosmos_id=42,
):
    """
    Insère une initiative de test en base et retourne l'objet créé.
    Utilisable dans setUpClass pour préparer le contexte.
    """
    initiative = Initiative(
        name=name,
        summary=summary,
        product_type=product_type,
        initiative_type=initiative_type,
        sponsor=sponsor,
        sponsor_country=sponsor_country,
        asset_class=asset_class,
        management_company=management_company,
        committee_date=committee_date,
        distribution_channel=distribution_channel,
        governance_required=governance_required,
        legal_form=legal_form,
        initiative_owner=initiative_owner,
        cosmos_id=cosmos_id,
    )
    db.session.add(initiative)
    db.session.commit()
    return initiative
