class TestPostInitiative(unittest.TestCase):

    @classmethod
    def setUpClass(cls):
        cls.client = server.test_client()
        cls.url = BASE_URL

        cls.patcher_parse = patch(
            "decorators.parse_params", side_effect=lambda f: f
        )
        cls.patcher_parse.start()

        cls.patcher_auth = patch(
            "util.required_plm_authentication.authorized_plm_roles",
            side_effect=lambda roles: lambda f: f,
        )
        cls.patcher_auth.start()

        cls.patcher_cm_enter = patch(
            "utils.src.context_managers.session_critical_action_manager"
            ".SessionCriticalActionManager.__enter__",
            return_value=None,
        )
        cls.patcher_cm_enter.start()

        cls.patcher_cm_exit = patch(
            "utils.src.context_managers.session_critical_action_manager"
            ".SessionCriticalActionManager.__exit__",
            return_value=False,
        )
        cls.patcher_cm_exit.start()

        init_database()

    @classmethod
    def tearDownClass(cls):
        cls.patcher_parse.stop()
        cls.patcher_auth.stop()
        cls.patcher_cm_enter.stop()
        cls.patcher_cm_exit.stop()

    def _valid_payload(self, **overrides):
        base = {
            "name": "New Initiative",
            "summary": "A summary",
            "product_type": "EQUITY",
            "initiative_type": "INTERNAL",
            "sponsor": "Sponsor SA",
            "sponsor_country": "FR",
            "asset_class": "EQUITY",
            "management_company": "Flowr",
            "committee_date": "2024-01-15",
            "distribution_channel": "DIRECT",
            "governance_required": "NO",
            "legal_form": "FCP",
            "initiative_owner": "owner@flowr.com",
            "cosmos_id": 99,
        }
        base.update(overrides)
        return base

    def test_post_initiative_returns_200(self):
        payload = self._valid_payload(name="Post Test Fund")
        response = self.client.post(
            self.url,
            data=json.dumps(payload),
            headers={**json_headers(), **auth_header()},
        )
        self.assertEqual(response.status_code, 200)

    def test_post_initiative_returns_created_name(self):
        payload = self._valid_payload(name="Created Fund")
        response = self.client.post(
            self.url,
            data=json.dumps(payload),
            headers={**json_headers(), **auth_header()},
        )
        data = json.loads(response.data)
        self.assertEqual(data[0]["name"], "Created Fund")

    def test_post_initiative_returns_list(self):
        payload = self._valid_payload(name="List Check Fund")
        response = self.client.post(
            self.url,
            data=json.dumps(payload),
            headers={**json_headers(), **auth_header()},
        )
        data = json.loads(response.data)
        self.assertIsInstance(data, list)
        self.assertEqual(len(data), 1)

    def test_post_initiative_id_auto_generated(self):
        """L'id est auto-généré par generate_custom_id et commence par 'I'."""
        payload = self._valid_payload(name="ID Check Fund")
        response = self.client.post(
            self.url,
            data=json.dumps(payload),
            headers={**json_headers(), **auth_header()},
        )
        data = json.loads(response.data)
        self.assertIn("id", data[0])
        self.assertTrue(
            data[0]["id"].startswith("I"),
            f"L'id devrait commencer par 'I', reçu : {data[0]['id']}",
        )

    def test_post_initiative_product_type_optional(self):
        """product_type est nullable=True → peut être absent du payload."""
        payload = self._valid_payload(name="No Product Type Fund")
        payload.pop("product_type", None)
        response = self.client.post(
            self.url,
            data=json.dumps(payload),
            headers={**json_headers(), **auth_header()},
        )
        self.assertEqual(response.status_code, 200)

    def test_post_initiative_sponsor_country_in_response(self):
        payload = self._valid_payload(name="Country Check", sponsor_country="LU")
        response = self.client.post(
            self.url,
            data=json.dumps(payload),
            headers={**json_headers(), **auth_header()},
        )
        data = json.loads(response.data)
        self.assertEqual(data[0]["sponsor_country"], "LU")


