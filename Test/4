class TestInactiveInitiatives(unittest.TestCase):
    """
    is_active=False → exclues de GET /initiatives et 404 sur GET by id.
    """

    @classmethod
    def setUpClass(cls):
        cls.client = server.test_client()

        cls.patcher_parse = patch(
            "decorators.parse_params", side_effect=lambda f: f
        )
        cls.patcher_parse.start()

        cls.patcher_auth = patch(
            "util.required_plm_authentication.authorized_plm_roles",
            side_effect=lambda roles: lambda f: f,
        )
        cls.patcher_auth.start()

        init_database()
        cls.active = insert_initiative(name="Active Initiative")

        # Initiative inactive — TOUS les args positionnels obligatoires fournis
        inactive = insert_initiative(
            name="Inactive Initiative",
            summary="Should not appear",
            product_type="EQUITY",
            initiative_type="INTERNAL",
            sponsor="X",
            sponsor_country="FR",
            asset_class="EQUITY",
            management_company="Flowr",
            distribution_channel="DIRECT",
            governance_required="NO",
            legal_form="FCP",
            initiative_owner="owner@flowr.com",
            cosmos_id=0,
        )
        # Désactiver après insertion
        from db import db as _db
        inactive.is_active = False
        _db.session.commit()
        cls.inactive_id = inactive.id

    @classmethod
    def tearDownClass(cls):
        cls.patcher_parse.stop()
        cls.patcher_auth.stop()

    def test_get_all_excludes_inactive(self):
        response = self.client.get(BASE_URL, headers=auth_header())
        data = json.loads(response.data)
        names = [i["name"] for i in data]
        self.assertNotIn("Inactive Initiative", names)
        self.assertIn("Active Initiative", names)

    def test_get_by_id_inactive_returns_404(self):
        url = f"{BASE_URL}/{self.inactive_id}"
        response = self.client.get(url, headers=auth_header())
        self.assertEqual(response.status_code, 404)


if __name__ == "__main__":
    unittest.main()
