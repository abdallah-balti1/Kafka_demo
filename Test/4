class TestPatchInitiativeById(unittest.TestCase):

    @classmethod
    def setUpClass(cls):
        cls.client = server.test_client()

        cls.patcher_parse = patch(
            "decorators.parse_params", side_effect=lambda f: f
        )
        cls.patcher_parse.start()

        cls.patcher_auth = patch(
            "util.required_plm_authentication.authorized_plm_roles",
            side_effect=lambda roles: lambda f: f,
        )
        cls.patcher_auth.start()

        cls.patcher_cm_enter = patch(
            "utils.src.context_managers.session_critical_action_manager"
            ".SessionCriticalActionManager.__enter__",
            return_value=None,
        )
        cls.patcher_cm_enter.start()

        cls.patcher_cm_exit = patch(
            "utils.src.context_managers.session_critical_action_manager"
            ".SessionCriticalActionManager.__exit__",
            return_value=False,
        )
        cls.patcher_cm_exit.start()

        init_database()
        cls.initiative = insert_initiative(
            name="Original Name",
            sponsor="Old Sponsor",
            summary="Initial summary",
        )
        cls.url = f"{BASE_URL}/{cls.initiative.id}"
        cls.unknown_url = f"{BASE_URL}/UNKNOWN-999"

    @classmethod
    def tearDownClass(cls):
        cls.patcher_parse.stop()
        cls.patcher_auth.stop()
        cls.patcher_cm_enter.stop()
        cls.patcher_cm_exit.stop()

    def test_patch_returns_200(self):
        payload = {"name": "Updated Name"}
        response = self.client.patch(
            self.url,
            data=json.dumps(payload),
            headers={**json_headers(), **auth_header()},
        )
        self.assertEqual(response.status_code, 200)

    def test_patch_updates_name(self):
        payload = {"name": "Patched Fund Name"}
        response = self.client.patch(
            self.url,
            data=json.dumps(payload),
            headers={**json_headers(), **auth_header()},
        )
        data = json.loads(response.data)
        self.assertEqual(data[0]["name"], "Patched Fund Name")

    def test_patch_updates_sponsor(self):
        payload = {"sponsor": "New Sponsor Corp"}
        response = self.client.patch(
            self.url,
            data=json.dumps(payload),
            headers={**json_headers(), **auth_header()},
        )
        data = json.loads(response.data)
        self.assertEqual(data[0]["sponsor"], "New Sponsor Corp")

    def test_patch_id_field_not_updatable(self):
        """'id' est dans not_allowed dans modify() → ne doit pas changer."""
        original_id = self.initiative.id
        payload = {"id": "FORCED-ID", "name": "Attempt"}
        response = self.client.patch(
            self.url,
            data=json.dumps(payload),
            headers={**json_headers(), **auth_header()},
        )
        data = json.loads(response.data)
        self.assertEqual(data[0]["id"], original_id)

    def test_patch_unknown_id_returns_404(self):
        payload = {"name": "Ghost"}
        response = self.client.patch(
            self.unknown_url,
            data=json.dumps(payload),
            headers={**json_headers(), **auth_header()},
        )
        self.assertEqual(response.status_code, 404)

    def test_patch_none_values_not_applied(self):
        """modify() ignore les valeurs None → summary existant conservé."""
        response = self.client.patch(
            self.url,
            data=json.dumps({"summary": None}),
            headers={**json_headers(), **auth_header()},
        )
        data = json.loads(response.data)
        self.assertEqual(data[0]["summary"], "Initial summary")


