"""
test/api/initiative/test_initiative.py

Tests d'intégration — endpoints Initiative
Pattern identique à test_product_object_data.py du projet flowr-api :
  - unittest.TestCase + setUpClass
  - server.test_client()
  - patch des decorators pour bypasser auth
  - init_database() + insert_initiative() pour seed

CORRECTIONS v2 :
  - URL préfixée avec APPLICATION_ROOT (ex: /initiative-pipeline/initiatives)
  - Initiative inactive créée avec TOUS les arguments positionnels obligatoires
  - Patch ciblé sur les bons chemins de modules
"""

import json
import unittest
from unittest.mock import patch

from config import APPLICATION_ROOT
from helpers import init_database, insert_initiative
from server import server

# URL de base complète avec le prefix applicatif
BASE_URL = f"{APPLICATION_ROOT}/initiatives"


def json_headers():
    return {"Content-Type": "application/json"}


def auth_header():
    return {"Authorization": "Bearer test-token"}


# ---------------------------------------------------------------------------
# GET /initiatives
# ---------------------------------------------------------------------------

class TestGetInitiatives(unittest.TestCase):

    @classmethod
    def setUpClass(cls):
        cls.client = server.test_client()
        cls.url = BASE_URL

        cls.patcher_parse = patch(
            "decorators.parse_params", side_effect=lambda f: f
        )
        cls.patcher_parse.start()

        cls.patcher_auth = patch(
            "util.required_plm_authentication.authorized_plm_roles",
            side_effect=lambda roles: lambda f: f,
        )
        cls.patcher_auth.start()

        init_database()
        cls.initiative_1 = insert_initiative(name="Alpha Fund")
        cls.initiative_2 = insert_initiative(name="Beta Fund", sponsor_country="LU")

    @classmethod
    def tearDownClass(cls):
        cls.patcher_parse.stop()
        cls.patcher_auth.stop()

    def test_get_initiatives_returns_200(self):
        response = self.client.get(self.url, headers=auth_header())
        self.assertEqual(response.status_code, 200)

    def test_get_initiatives_returns_list(self):
        response = self.client.get(self.url, headers=auth_header())
        data = json.loads(response.data)
        self.assertIsInstance(data, list)

    def test_get_initiatives_returns_seeded_count(self):
        response = self.client.get(self.url, headers=auth_header())
        data = json.loads(response.data)
        self.assertEqual(len(data), 2)

    def test_get_initiatives_contains_expected_fields(self):
        response = self.client.get(self.url, headers=auth_header())
        data = json.loads(response.data)
        first = data[0]
        for field in ["id", "name", "summary", "sponsor", "sponsor_country",
                      "asset_class", "distribution_channel", "legal_form",
                      "initiative_owner", "cosmos_id"]:
            self.assertIn(field, first, f"Champ manquant : {field}")

    def test_get_initiatives_name_alpha_present(self):
        response = self.client.get(self.url, headers=auth_header())
        data = json.loads(response.data)
        names = [i["name"] for i in data]
        self.assertIn("Alpha Fund", names)

    def test_get_initiatives_name_beta_present(self):
        response = self.client.get(self.url, headers=auth_header())
        data = json.loads(response.data)
        names = [i["name"] for i in data]
        self.assertIn("Beta Fund", names)


