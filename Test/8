import json
import unittest
from unittest.mock import patch, MagicMock

from config import APPLICATION_ROOT
from helpers import init_database, insert_initiative, insert_initiative_data
from server import server

BASE_URL = f"{APPLICATION_ROOT}/initiatives-data"
BASE_URL_BY_ID = f"{APPLICATION_ROOT}/initiatives"

PATCH_ME = "util.required_plm_authentication._me"
PATCH_PARSE = "decorators.parse_params"
PATCH_CM_ENTER = (
    "utils.src.context_managers.session_critical_action_manager"
    ".SessionCriticalActionManager.__enter__"
)
PATCH_CM_EXIT = (
    "utils.src.context_managers.session_critical_action_manager"
    ".SessionCriticalActionManager.__exit__"
)


def json_headers():
    return {"Content-Type": "application/json"}


def auth_header():
    return {"Authorization": "Bearer test-token"}


def make_fake_me_response():
    fake_response = MagicMock()
    fake_response.status_code = 200
    fake_response.json.return_value = {
        "uid": "owner@flowr.com",
        "roles": [
            "INITIATIVE_OWNER",
            "INITIATIVE_COORDINATOR",
            "INITIATIVE_OBSERVER",
            "INITIATIVE_OVERSIGHT",
            "INITIATIVE_ASSESSOR",
            "ADMIN",
        ],
    }
    return fake_response


class TestGetInitiativeData(unittest.TestCase):

    @classmethod
    def setUpClass(cls):
        cls.client = server.test_client()
        cls.url = BASE_URL

        cls.patcher_me = patch(PATCH_ME, return_value=make_fake_me_response())
        cls.patcher_me.start()

        cls.patcher_parse = patch(PATCH_PARSE, side_effect=lambda f: f)
        cls.patcher_parse.start()

        init_database()
        cls.initiative = insert_initiative(name="Fund A")
        cls.data_1 = insert_initiative_data(
            id_initiative=cls.initiative.id,
            client_name="Client Alpha",
        )
        cls.data_2 = insert_initiative_data(
            id_initiative=cls.initiative.id,
            client_name="Client Beta",
        )

    @classmethod
    def tearDownClass(cls):
        cls.patcher_me.stop()
        cls.patcher_parse.stop()

    def _get_list(self):
        response = self.client.get(self.url, headers=auth_header())
        return response, json.loads(response.data)

    def test_get_initiative_data_returns_200(self):
        # check that the endpoint is reachable
        response, _ = self._get_list()
        self.assertEqual(response.status_code, 200)

    def test_get_initiative_data_returns_list(self):
        # check that the response is a list
        _, data = self._get_list()
        self.assertIsInstance(data, list)

    def test_get_initiative_data_returns_seeded_count(self):
        # check that all seeded initiative data are returned
        _, data = self._get_list()
        self.assertEqual(len(data), 2)

    def test_get_initiative_data_contains_expected_fields(self):
        # check that each item has the required fields
        _, data = self._get_list()
        first = data[0]
        for field in [
            "id", "id_initiative", "client_name", "client_type",
            "salesforce_id_opportunity", "aum_expected", "fees_desc",
        ]:
            self.assertIn(field, first)

    def test_get_initiative_data_client_alpha_present(self):
        # check that Client Alpha is in the response
        _, data = self._get_list()
        self.assertIn("Client Alpha", [d["client_name"] for d in data])

    def test_get_initiative_data_client_beta_present(self):
        # check that Client Beta is in the response
        _, data = self._get_list()
        self.assertIn("Client Beta", [d["client_name"] for d in data])


