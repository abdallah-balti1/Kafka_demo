import io
import json
import unittest
from unittest.mock import patch, MagicMock

from config import APPLICATION_ROOT
from test.helpers import init_database, insert_initiative, insert_document, insert_document_type
from server import server

BASE_URL = f"{APPLICATION_ROOT}/documents"

PATCH_ME = "util.required_plm_authentication._me"
PATCH_CM = "context_managers.SessionCriticalActionManager"
PATCH_MAILER = "clients.mailer"
PATCH_COS_WRITE = "resources.document.document.cos_write_file"
PATCH_COS_READ = "resources.document.document_by_id.cos_read_file"
PATCH_COS_DELETE = "resources.document.document_by_id.cos_delete_file"


def auth_header():
    return {"Authorization": "Bearer test-token"}


def make_fake_me_response():
    fake = MagicMock()
    fake.status_code = 200
    fake.json.return_value = {
        "uid": "owner@flowr.com",
        "roles": [
            "INITIATIVE_OWNER",
            "INITIATIVE_COORDINATOR",
            "INITIATIVE_OBSERVER",
            "INITIATIVE_OVERSIGHT",
            "INITIATIVE_ASSESSOR",
            "ADMIN",
        ],
    }
    return fake


def start_common_patches(cls):
    cls.patcher_me = patch(PATCH_ME, return_value=make_fake_me_response())
    cls.patcher_me.start()
    cls.patcher_mailer = patch(PATCH_MAILER, MagicMock())
    cls.patcher_mailer.start()
    cls.patcher_cm = patch(PATCH_CM)
    mock_cm = cls.patcher_cm.start()
    mock_cm.return_value.__enter__ = lambda s: None
    mock_cm.return_value.__exit__ = lambda s, *a: False


def stop_common_patches(cls):
    cls.patcher_me.stop()
    cls.patcher_mailer.stop()
    cls.patcher_cm.stop()


class TestGetDocuments(unittest.TestCase):
    """
    A user wants to see the list of documents available on the platform.
    They can optionally filter by initiative.
    """

    @classmethod
    def setUpClass(cls):
        cls.client = server.test_client()
        start_common_patches(cls)
        init_database()
        cls.initiative = insert_initiative(name="Doc Fund")
        cls.doc_report = insert_document(
            filename="report",
            extension=".pdf",
            initiative_id=cls.initiative.id,
        )
        cls.doc_summary = insert_document(
            filename="summary",
            extension=".docx",
            initiative_id=cls.initiative.id,
        )

    @classmethod
    def tearDownClass(cls):
        stop_common_patches(cls)

    def _get(self, params=None):
        response = self.client.get(
            BASE_URL,
            query_string=params or {},
            headers=auth_header(),
        )
        return response, json.loads(response.data)

    def test_documents_list_is_accessible(self):
        # a user can reach the documents endpoint without errors
        response, _ = self._get()
        self.assertEqual(response.status_code, 200)

    def test_documents_list_returns_a_list(self):
        # the response is a list, not a single object
        _, data = self._get()
        self.assertIsInstance(data, list)

    def test_documents_list_contains_all_seeded_documents(self):
        # all documents inserted before the test are visible in the list
        _, data = self._get()
        self.assertGreaterEqual(len(data), 2)

    def test_each_document_has_the_expected_fields(self):
        # every document in the list exposes id, filename, extension, initiative and deletable flag
        _, data = self._get()
        first = data[0]
        for field in ["id", "filename", "extension", "initiative_id", "is_deletable"]:
            self.assertIn(field, first)

    def test_filtering_by_initiative_returns_only_matching_documents(self):
        # when a user filters by initiative, only documents linked to that initiative appear
        _, data = self._get(params={"id_initiative": self.initiative.id})
        ids = [d["initiative_id"] for d in data]
        self.assertTrue(all(i == self.initiative.id for i in ids))

    def test_report_document_appears_in_the_list(self):
        # the report document uploaded earlier is visible in the list
        _, data = self._get()
        self.assertIn("report", [d["filename"] for d in data])

    def test_summary_document_appears_in_the_list(self):
        # the summary document uploaded earlier is visible in the list
        _, data = self._get()
        self.assertIn("summary", [d["filename"] for d in data])


class TestPostDocument(unittest.TestCase):
    """
    A user uploads a document to the platform.
    The file is stored in the cloud object storage and linked to an initiative.
    """

    @classmethod
    def setUpClass(cls):
        cls.client = server.test_client()
        start_common_patches(cls)
        cls.patcher_cos_write = patch(PATCH_COS_WRITE, return_value=None)
        cls.patcher_cos_write.start()
        init_database()
        cls.initiative = insert_initiative(name="Upload Fund")
        cls.document_type = insert_document_type(name="Prospectus")

    @classmethod
    def tearDownClass(cls):
        stop_common_patches(cls)
        cls.patcher_cos_write.stop()

    def _post(self, filename="test.pdf", initiative_id=None, document_type_id=None):
        if document_type_id is None:
            document_type_id = self.__class__.document_type.id
        file_data = io.BytesIO(b"fake file content")
        data = {
            "file": (file_data, filename),
            "document_type_id": document_type_id,
        }
        if initiative_id:
            data["initiative_id"] = initiative_id
        response = self.client.post(
            BASE_URL,
            data=data,
            headers=auth_header(),
            content_type="multipart/form-data",
        )
        return response, json.loads(response.data)

    def test_uploading_a_document_succeeds(self):
        # a user uploads a file and gets a 201 confirmation
        response, _ = self._post(
            filename="upload.pdf",
            initiative_id=self.__class__.initiative.id,
        )
        self.assertEqual(response.status_code, 201)

    def test_uploaded_document_has_the_correct_filename(self):
        # the filename is stored without its extension
        _, data = self._post(
            filename="myreport.pdf",
            initiative_id=self.__class__.initiative.id,
        )
        self.assertEqual(data["filename"], "myreport")

    def test_uploaded_document_has_the_correct_extension(self):
        # the file extension is stored separately
        _, data = self._post(
            filename="myreport.pdf",
            initiative_id=self.__class__.initiative.id,
        )
        self.assertEqual(data["extension"], ".pdf")

    def test_uploaded_document_is_linked_to_the_initiative(self):
        # the document is associated with the initiative the user specified
        initiative_id = self.__class__.initiative.id
        _, data = self._post(
            filename="linked.pdf",
            initiative_id=initiative_id,
        )
        self.assertEqual(data["initiative_id"], initiative_id)

    def test_file_is_sent_to_cloud_storage_on_upload(self):
        # when a document is uploaded, it is written to the cloud object storage
        with patch(PATCH_COS_WRITE) as mock_write:
            self._post(
                filename="costest.pdf",
                initiative_id=self.__class__.initiative.id,
            )
            mock_write.assert_called_once()


class TestGetDocumentById(unittest.TestCase):
    """
    A user downloads a specific document by its id.
    The file content is fetched from cloud storage and returned as a file download.
    """

    @classmethod
    def setUpClass(cls):
        cls.client = server.test_client()
        start_common_patches(cls)
        cls.patcher_cos_read = patch(PATCH_COS_READ, return_value=b"fake content")
        cls.patcher_cos_read.start()
        init_database()
        cls.initiative = insert_initiative(name="Read Fund")
        cls.document = insert_document(
            filename="readable",
            extension=".pdf",
            initiative_id=cls.initiative.id,
        )
        cls.url = f"{BASE_URL}/{cls.document.id}"
        cls.unknown_url = f"{BASE_URL}/99999"

    @classmethod
    def tearDownClass(cls):
        stop_common_patches(cls)
        cls.patcher_cos_read.stop()

    def test_downloading_an_existing_document_succeeds(self):
        # a user can download a document that exists in the system
        response = self.client.get(self.url, headers=auth_header())
        self.assertEqual(response.status_code, 200)

    def test_downloading_a_nonexistent_document_returns_not_found(self):
        # if the document id does not exist, the user gets a 404
        response = self.client.get(self.unknown_url, headers=auth_header())
        self.assertEqual(response.status_code, 404)

    def test_file_is_fetched_from_cloud_storage_on_download(self):
        # the file content is retrieved from the cloud object storage when downloading
        with patch(PATCH_COS_READ, return_value=b"content") as mock_read:
            self.client.get(self.url, headers=auth_header())
            mock_read.assert_called_once()


class TestDeleteDocument(unittest.TestCase):
    """
    A user deletes a document from the platform.
    Only documents marked as deletable can be removed.
    """

    @classmethod
    def setUpClass(cls):
        cls.client = server.test_client()
        start_common_patches(cls)
        cls.patcher_cos_delete = patch(PATCH_COS_DELETE, return_value=None)
        cls.patcher_cos_delete.start()
        init_database()
        cls.initiative = insert_initiative(name="Delete Fund")

    @classmethod
    def tearDownClass(cls):
        stop_common_patches(cls)
        cls.patcher_cos_delete.stop()

    def _insert_deletable(self):
        return insert_document(
            filename="to_delete",
            extension=".pdf",
            initiative_id=self.__class__.initiative.id,
            is_deletable=True,
        )

    def _insert_non_deletable(self):
        return insert_document(
            filename="protected",
            extension=".pdf",
            initiative_id=self.__class__.initiative.id,
            is_deletable=False,
        )

    def test_deleting_a_deletable_document_succeeds(self):
        # a user can delete a document that is marked as deletable
        doc = self._insert_deletable()
        response = self.client.delete(
            f"{BASE_URL}/{doc.id}", headers=auth_header()
        )
        self.assertEqual(response.status_code, 200)

    def test_deleting_a_nonexistent_document_returns_not_found(self):
        # trying to delete a document that does not exist returns a 404
        response = self.client.delete(
            f"{BASE_URL}/99999", headers=auth_header()
        )
        self.assertEqual(response.status_code, 404)

    def test_deleting_a_protected_document_is_refused(self):
        # a document marked as non-deletable cannot be removed — the server refuses with 403
        doc = self._insert_non_deletable()
        response = self.client.delete(
            f"{BASE_URL}/{doc.id}", headers=auth_header()
        )
        self.assertEqual(response.status_code, 403)

    def test_file_is_removed_from_cloud_storage_when_deleted(self):
        # when a document is deleted and an initiative is specified, the file is removed from cloud storage
        doc = self._insert_deletable()
        with patch(PATCH_COS_DELETE) as mock_delete:
            self.client.delete(
                f"{BASE_URL}/{doc.id}",
                query_string={"initiative_id": self.__class__.initiative.id},
                headers=auth_header(),
            )
            mock_delete.assert_called_once()


if __name__ == "__main__":
    unittest.main()
