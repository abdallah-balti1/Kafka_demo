class TestPatchInitiativeById(unittest.TestCase):

    @classmethod
    def setUpClass(cls):
        cls.client = server.test_client()

        cls.patcher_me = patch(PATCH_ME, return_value=make_fake_me_response())
        cls.patcher_me.start()

        cls.patcher_parse = patch(PATCH_PARSE, side_effect=lambda f: f)
        cls.patcher_parse.start()

        cls.patcher_cm_enter = patch(PATCH_CM_ENTER, return_value=None)
        cls.patcher_cm_enter.start()

        cls.patcher_cm_exit = patch(PATCH_CM_EXIT, return_value=False)
        cls.patcher_cm_exit.start()

        init_database()
        cls.initiative = insert_initiative(
            name="Original Name",
            sponsor="Old Sponsor",
            summary="Initial summary",
        )
        cls.url = f"{BASE_URL}/{cls.initiative.id}"
        cls.unknown_url = f"{BASE_URL}/UNKNOWN-999"

    @classmethod
    def tearDownClass(cls):
        cls.patcher_me.stop()
        cls.patcher_parse.stop()
        cls.patcher_cm_enter.stop()
        cls.patcher_cm_exit.stop()

    def _patch(self, url, payload):
        response = self.client.patch(
            url,
            data=json.dumps(payload),
            headers={**json_headers(), **auth_header()},
        )
        return response, json.loads(response.data)

    def test_patch_returns_200(self):
        # check that patching an existing initiative returns 200
        response, _ = self._patch(self.url, {"name": "Updated Name"})
        self.assertEqual(response.status_code, 200)

    def test_patch_updates_name(self):
        # check that the name is correctly updated
        _, data = self._patch(self.url, {"name": "Patched Fund Name"})
        self.assertEqual(data[0]["name"], "Patched Fund Name")

    def test_patch_updates_sponsor(self):
        # check that the sponsor is correctly updated
        _, data = self._patch(self.url, {"sponsor": "New Sponsor Corp"})
        self.assertEqual(data[0]["sponsor"], "New Sponsor Corp")

    def test_patch_id_not_updatable(self):
        # check that the id field cannot be modified
        original_id = self.__class__.initiative.id
        _, data = self._patch(self.url, {"id": "FORCED-ID", "name": "Attempt"})
        self.assertEqual(data[0]["id"], original_id)

    def test_patch_unknown_id_returns_404(self):
        # check that patching a non-existent initiative returns 404
        response, _ = self._patch(self.unknown_url, {"name": "Ghost"})
        self.assertEqual(response.status_code, 404)

    def test_patch_none_value_not_applied(self):
        # check that passing None does not overwrite the existing value
        _, data = self._patch(self.url, {"summary": None})
        self.assertEqual(data[0]["summary"], "Initial summary")


class TestInactiveInitiatives(unittest.TestCase):

    @classmethod
    def setUpClass(cls):
        cls.client = server.test_client()

        cls.patcher_me = patch(PATCH_ME, return_value=make_fake_me_response())
        cls.patcher_me.start()

        cls.patcher_parse = patch(PATCH_PARSE, side_effect=lambda f: f)
        cls.patcher_parse.start()

        init_database()
        cls.active = insert_initiative(name="Active Initiative")

        inactive = insert_initiative(
            name="Inactive Initiative",
            summary="Should not appear",
            product_type="EQUITY",
            initiative_type="INTERNAL",
            sponsor="X",
            sponsor_country="FR",
            asset_class="EQUITY",
            management_company="Flowr",
            distribution_channel="DIRECT",
            governance_required="NO",
            legal_form="FCP",
            initiative_owner="owner@flowr.com",
            cosmos_id=0,
        )
        from db import db as _db
        inactive.is_active = False
        _db.session.commit()
        cls.inactive_id = inactive.id

    @classmethod
    def tearDownClass(cls):
        cls.patcher_me.stop()
        cls.patcher_parse.stop()

    def test_get_all_excludes_inactive(self):
        # check that initiatives with is_active=False are not returned
        response = self.client.get(BASE_URL, headers=auth_header())
        data = json.loads(response.data)
        self.assertIsInstance(data, list)
        names = [i["name"] for i in data]
        self.assertNotIn("Inactive Initiative", names)
        self.assertIn("Active Initiative", names)

    def test_get_by_id_inactive_returns_404(self):
        # check that fetching an inactive initiative by id returns 404
        url = f"{BASE_URL}/{self.__class__.inactive_id}"
        response = self.client.get(url, headers=auth_header())
        self.assertEqual(response.status_code, 404)


if __name__ == "__main__":
    unittest.main()
