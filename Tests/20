import uuid

from db import db
from models import Initiative, InitiativeData, InitiativeDocument, InitiativeDocumentType


def init_database():
    # reset the database to a clean state before each test class runs
    try:
        delete_all_data()
    except Exception:
        db.create_all()


def delete_all_data():
    # remove all records in the right order to respect foreign key constraints
    reset_table(InitiativeDocument)
    reset_table(InitiativeDocumentType)
    reset_table(InitiativeData)
    reset_table(Initiative)
    db.session.commit()
    db.session.expunge_all()


def reset_table(model):
    # wipe all rows from a table and reset its auto-increment counter
    from sqlalchemy.sql.expression import text
    if hasattr(model, "__table__"):
        tablename = model.__tablename__
        db.session.execute(
            text(f"TRUNCATE TABLE {tablename} RESTART IDENTITY CASCADE")
        )


