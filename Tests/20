def insert_document(
    filename="test_file",
    extension=".pdf",
    initiative_id=None,
    is_deletable=True,
    document_type_id=None,
):
    # create a document record in the database — the actual file is not written to storage
    document = InitiativeDocument(
        filename=filename,
        extension=extension,
        initiative_id=initiative_id,
        is_deletable=is_deletable,
        document_type_id=document_type_id,
    )
    db.session.add(document)
    db.session.flush()
    db.session.commit()
    db.session.refresh(document)
    return document


def insert_document_type(name="Default Type"):
    # create a document type that documents can be categorised under
    doc_type = InitiativeDocumentType(name=name)
    db.session.add(doc_type)
    db.session.flush()
    db.session.commit()
    db.session.refresh(doc_type)
    return doc_type
