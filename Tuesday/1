from flask_restful import Resource
from util.required_plm_authentication import authorized_plm_roles
from db import db
from models.template import Template


class TemplatesResource(Resource):
    """Get all templates"""

    @staticmethod
    @authorized_plm_roles(
        [
            "INITIATIVE_OWNER",
            "INITIATIVE_COORDINATOR",
            "ADMIN",
            "INITIATIVE_ASSESSOR",
            "INITIATIVE_OVERSIGHT",
            "INITIATIVE_OBSERVER",
        ]
    )
    def get(user):
        templates = db.session.query(Template).all()
        return [{"id": t.id, "name": t.name} for t in templates]
