repos:
  - repo: local
    hooks:
      - id: isort
        name: isort
        entry: isort
        language: system
        types: [python]
        args: ["--profile=black", "--line-length=120"]

      - id: black
        name: black
        entry: black
        language: system
        types: [python]
        args: ["--line-length=120"]

      - id: ruff
        name: ruff
        entry: ruff
        language: system
        types: [python]
        args: ["check", "--fix"]
